<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<GridPane alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
          prefHeight="600.0" prefWidth="600.0"
          hgap="10.0" vgap="10.0"
          xmlns:fx="http://javafx.com/fxml/1"
          xmlns="http://javafx.com/javafx/17"
          fx:controller="application.SimonController">

    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
    </padding>

    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="45.0" />
        <RowConstraints minHeight="10.0" prefHeight="60.0" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    </rowConstraints>

    <children>
        <Label fx:id="scoreLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" text="SCORE: 0">
            <GridPane.margin>
                <Insets top="4.0" left="4.0" right="4.0" bottom="4.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="24.0" />
            </font>
        </Label>

        <Label fx:id="highScoreLabel" alignment="CENTER" maxWidth="1.7976931348623157E308"
               text="HIGH SCORE: 0" GridPane.columnIndex="1">
            <GridPane.margin>
                <Insets top="4.0" left="4.0" right="4.0" bottom="4.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="24.0" />
            </font>
        </Label>

        <Button fx:id="startButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                onAction="#handleStart" text="START GAME"
                GridPane.rowIndex="1" GridPane.columnSpan="2">
            <GridPane.margin>
                <Insets bottom="8.0" left="10.0" right="10.0" top="4.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="24.0" />
            </font>
        </Button>

        <Button fx:id="redButton" alignment="CENTER" contentDisplay="CENTER"
                maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#handleRed"
                style="-fx-background-color: red;" text="RED" GridPane.rowIndex="2">
            <GridPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="48.0" />
            </font>
        </Button>

        <Button fx:id="greenButton"
                maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#handleGreen"
                style="-fx-background-color: green;" text="GREEN"
                GridPane.columnIndex="1" GridPane.rowIndex="2">
            <GridPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="40.0" />
            </font>
        </Button>

        <Button fx:id="yellowButton"
                maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#handleYellow"
                style="-fx-background-color: yellow;" text="YELLOW"
                GridPane.rowIndex="3">
            <GridPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="38.0" />
            </font>
        </Button>

        <Button fx:id="blueButton"
                maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                mnemonicParsing="false" onAction="#handleBlue"
                style="-fx-background-color: blue;" text="BLUE"
                GridPane.columnIndex="1" GridPane.rowIndex="3">
            <GridPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </GridPane.margin>
            <font>
                <Font name="Courier New Bold" size="48.0" />
            </font>
        </Button>
    </children>
</GridPane>